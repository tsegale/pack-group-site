# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Server
PORT=3000
NODE_ENV=development

# Session secret — generate a strong random string (e.g. openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-long-random-secret

# Initial admin user created by the seed script
ADMIN_NAME=Pack Admin
ADMIN_EMAIL=admin@packgroup.na
ADMIN_PASSWORD=ChangeMe123!
