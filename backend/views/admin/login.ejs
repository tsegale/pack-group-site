<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login | Pack Group</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/admin-assets/css/admin.css">
</head>
<body class="login-page-body">
<div class="login-wrap">
  <div class="login-card">
    <img src="/assets/logo/packgroup_logo.png" alt="Pack Group" class="login-logo">
    <p class="login-subtitle">Admin Panel</p>
    <h1 class="login-heading">Welcome back.</h1>

    <% if (error) { %>
    <div class="alert alert-error">
      <i class="fa-solid fa-circle-exclamation"></i> <%= error %>
    </div>
    <% } %>

    <form method="POST" action="/admin/login" autocomplete="on">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="form-group">
        <label for="email">Email Address</label>
        <input type="email" id="email" name="email" placeholder="admin@packgroup.na" required autocomplete="email">
      </div>

      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="••••••••" required autocomplete="current-password">
      </div>

      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;font-size:14px;padding:11px;">
        <i class="fa-solid fa-arrow-right-to-bracket"></i> Sign In
      </button>
    </form>

    <p style="text-align:center;margin-top:20px;font-size:12px;color:var(--gray-mid);">
      Pack Group &bull; Internal Admin &bull; 2026
    </p>
  </div>
</div>
</body>
</html>
